pipeline {
    agent any

    stages {
        stage('Unit Tests backend') {
            agent {
                docker {
                    image 'snakee/golang-junit:1.21'
                    reuseNode true
                }
            }
            steps {
                dir('bugtracker-backend') {
                    sh 'go test -v ./...'
                }
            }
        }
        stage('Unit Tests frontent') {
            agent {
                docker {
                    image 'node:20-alpine'
                    reuseNode true
                }
            }
            steps {
                dir('bugtracker-frontent') {
                    sh '''
                      npm ci
                      npm test
                    '''
                }
            }
            post {
                always {
                    junit 'bugtracker-frontent/test-results.xml'
                }
            }
        }
    }
}
